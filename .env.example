# ── Database ──────────────────────────────────────────
# PostgreSQL credentials — must match values used in DATABASE_URL
POSTGRES_USER=coastfi
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=coastfi
# Full connection string used by SQLAlchemy and Alembic inside the app container
# The hostname "db" refers to the Postgres service name in podman-compose.yml
DATABASE_URL=postgresql://coastfi:changeme_in_production@db:5432/coastfi

# ── Application ───────────────────────────────────────
# Flask session secret — replace with a cryptographically random 32+ character string
SECRET_KEY=replace-with-a-random-32-char-string
# Set to "true" to enable Dash hot-reload in development (never true in production)
DASH_DEBUG=false
# Port the Dash app binds to inside the container (host mapping defined in podman-compose.yml)
APP_PORT=8050
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Optional: AI Advisor (stretch feature, leave blank for MVP) ──
# Anthropic API key — only needed if the AI advisor feature is enabled
ANTHROPIC_API_KEY=
